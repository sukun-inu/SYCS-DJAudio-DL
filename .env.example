# ══════════════════════════════════════════════════════════
#  このファイルを .env にコピーして値を入力してください
#  cp .env.example .env
# ══════════════════════════════════════════════════════════

# ────────────────────────────────────────────
# 【必須】Discord Bot トークン
# Discord Developer Portal > Applications > Bot > Token
# ────────────────────────────────────────────
DISCORD_TOKEN=ここにトークンを貼り付ける

# ────────────────────────────────────────────
# 【必須】Flask 配信サーバーのベース URL
#
# ドメインが決まったら:
#   BASE_URL=https://music.example.com
#
# ドメインなし・IPアドレスで直接アクセスする場合:
#   BASE_URL=http://123.456.789.0:5000
#
# ローカルテスト中:
#   BASE_URL=http://localhost:5000
# ────────────────────────────────────────────
BASE_URL=http://localhost:5000

# ────────────────────────────────────────────
# 【任意】キャッシュ有効期間（秒）
# デフォルト: 600（= 10分）
# 例: 1800 = 30分 / 3600 = 1時間
# ────────────────────────────────────────────
CACHE_TTL_SECONDS=600

# ────────────────────────────────────────────
# 【任意】Flask サーバーのポート番号
# デフォルト: 5000
# ────────────────────────────────────────────
FLASK_PORT=5000

# ────────────────────────────────────────────
# 【任意】デフォルトの監視チャンネル ID
# /setchannel コマンドで後から設定できるので空でもOK
# チャンネルIDの調べ方: Discord設定 > 詳細 > 開発者モードON
#                        → チャンネルを右クリック > IDをコピー
# ────────────────────────────────────────────
DEFAULT_CHANNEL_ID=
